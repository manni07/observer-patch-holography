{
  "oracle_bin": "./automation/oracle_patched/bin/oracle",
  "engine": "browser",
  "model": "5.4 Pro",
  "oracle_force": true,
  "verbose": true,
  "browser_model_strategy": "current",
  "browser_profile_seed_dir": "~/.oracle/browser-profile",
  "browser_bundle_files": true,
  "browser_reupload_attachments_on_thread_continue": false,
  "chatgpt_url": "https://chatgpt.com/",
  "browser_manual_login": true,
  "browser_keep_browser": false,
  "browser_timeout": "90m",
  "browser_auto_reattach_delay": "30s",
  "browser_auto_reattach_interval": "2m",
  "browser_auto_reattach_timeout": "2m",
  "browser_reuse_wait": "20s",
  "browser_profile_lock_timeout": "0s",
  "heartbeat": 30,
  "max_edit_rounds": 8,
  "max_audit_rounds": 2,
  "max_non_substantive_edit_rounds": 2,
  "smart_apply": {
    "enabled": true,
    "codex_bin": "codex",
    "model": "gpt-5.4",
    "sandbox": "read-only",
    "ephemeral": true
  },
  "local_structuring": {
    "enabled": true,
    "codex_bin": "codex",
    "model": "gpt-5.4",
    "sandbox": "read-only",
    "ephemeral": true
  },
  "release_gate": {
    "batch_size": 3,
    "consistency_task_id": "particles.gapbundle.integration-gate",
    "final_hygiene_task_id": "particles.gapbundle.integration-gate",
    "default_stage": "local"
  },
  "github_sync": {
    "enabled": false
  },
  "task_filter": {
    "include_prefixes": [
      "particles.gapbundle."
    ],
    "include_ids": []
  },
  "workers": [
    {
      "id": "particles-e29-worker",
      "oracle_home_dir": "~/.oracle-oph/particles-e29-worker",
      "browser_profile_dir": "~/.oracle-oph/particles-e29-worker/browser-profile",
      "browser_port": 9262
    },
    {
      "id": "particles-e30-worker",
      "oracle_home_dir": "~/.oracle-oph/particles-e30-worker",
      "browser_profile_dir": "~/.oracle-oph/particles-e30-worker/browser-profile",
      "browser_port": 9263
    },
    {
      "id": "particles-e32-worker",
      "oracle_home_dir": "~/.oracle-oph/particles-e32-worker",
      "browser_profile_dir": "~/.oracle-oph/particles-e32-worker/browser-profile",
      "browser_port": 9264
    }
  ],
  "supervisor": {
    "idle_sleep_seconds": 300,
    "stale_task_timeout_seconds": 7200,
    "heartbeat_interval_seconds": 60,
    "task_timeout_seconds": 21600,
    "max_task_attempts": 3
  }
}
